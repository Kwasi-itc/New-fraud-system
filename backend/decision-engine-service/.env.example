# Server
PORT=8082
GIN_MODE=debug
LOG_LEVEL=info

# Required service dependencies
DATABASE_URL=postgres://datamodel:datamodel@localhost:5434/datamodel?sslmode=disable
DATA_MODEL_SERVICE_URL=http://localhost:8080
INGESTION_SERVICE_URL=http://localhost:8081

# Service-to-service auth
SERVICE_AUTH_MODE=disabled
SERVICE_AUTH_TOKEN=
SERVICE_ALLOWED_ORIGINS=http://localhost:3000

# Optional downstream integrations
WORKFLOW_ACTION_URL=
SCREENING_SERVICE_URL=
SCREENING_PROVIDER_URL=
SCORING_PROVIDER_URL=
OUTBOX_PUBLISHER_URL=

# HTTP client behavior
HTTP_CLIENT_TIMEOUT=10s
ASYNC_EXECUTION_DEFAULT_WAIT_WINDOW=300ms
ASYNC_EXECUTION_MAX_WAIT_WINDOW=1s
ASYNC_EXECUTION_CALLBACK_TIMEOUT=5s
ASYNC_EXECUTION_CALLBACK_MAX_ATTEMPTS=5
ASYNC_EXECUTION_CALLBACK_QUEUE_NAME=async_decision_execution_callbacks
ASYNC_EXECUTION_CALLBACK_QUEUE_WORKERS=2
ASYNC_EXECUTION_CALLBACK_SIGNING_SECRET=

# Worker behavior
# Worker mode:
# - batch: process one cycle and exit
# - poll: keep running and poll on an interval
WORKER_MODE=poll
WORKER_POLL_INTERVAL=15s
WORKER_BATCH_LIMIT=100
