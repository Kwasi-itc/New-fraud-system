{
  "name": "geographic churn window boundaries",
  "object_type": "$transactions",
  "trigger": {
    "function": "constant",
    "constant": true
  },
  "thresholds": {
    "review": 1,
    "block_and_review": 3,
    "decline": 6
  },
  "variables": {
    "object_id": "geo_churn_target",
    "owner_id": "geo_churn_owner"
  },
  "generated_records": [
    {
      "object_type": "$transactions",
      "count": 2,
      "template": {
        "object_id": "$owner_id_gh_$index",
        "amount": 120,
        "status": "pending",
        "account_id": "acct-geo-gh-$index",
        "ip": "60.60.60.$index",
        "merchant": "Geo GH",
        "email": "geo-gh@example.com",
        "country": "gh",
        "owner_id": "$owner_id",
        "event_time": "$now_minus_30s",
        "note": "geo-gh"
      }
    },
    {
      "object_type": "$transactions",
      "count": 2,
      "template": {
        "object_id": "$owner_id_ng_$index",
        "amount": 120,
        "status": "pending",
        "account_id": "acct-geo-ng-$index",
        "ip": "61.61.61.$index",
        "merchant": "Geo NG",
        "email": "geo-ng@example.com",
        "country": "ng",
        "owner_id": "$owner_id",
        "event_time": "$now_minus_30s",
        "note": "geo-ng"
      }
    },
    {
      "object_type": "$transactions",
      "count": 2,
      "template": {
        "object_id": "$owner_id_ke_$index",
        "amount": 120,
        "status": "pending",
        "account_id": "acct-geo-ke-$index",
